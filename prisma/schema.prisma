generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SessionStatus {
  completed
  failed
  aborted
  running
}

enum LeadStatus {
  verified
  needs_enrich
  pending
  failed
}

enum UserPlan {
  starter
  professional
  business
  enterprise
}

model User {
  id               String     @id @default(cuid())
  name             String?
  email            String     @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  planType         UserPlan   @default(starter)
  creditsRemaining Int        @default(100)
  creditsLimit     Int        @default(100)
  apiKey           String?    @unique
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  accounts       Account[]
  sessions       Session[]
  scrapeSessions ScrapeSession[]
  exportHistory  ExportHistory[]
  userApiKeys    UserApiKey[]
  subscription   Subscription?
  payments       Payment[]
  webhookConfig  WebhookConfig?
  connectorConfigs ConnectorConfig[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                      String     @id @default(cuid())
  userId                  String     @unique
  planType                UserPlan   @default(starter)
  razorpaySubscriptionId  String?
  status                  String     @default("active")
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  creditsLimit            Int        @default(100)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id                 String    @id @default(cuid())
  subscriptionId     String?
  userId             String
  amount             Float
  currency           String    @default("INR")
  status             String
  razorpayOrderId    String?   @unique
  razorpayPaymentId  String?   @unique
  razorpaySignature  String?
  planType           UserPlan
  createdAt          DateTime  @default(now())

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
}

model ScrapeSession {
  id          String         @id @default(cuid())
  userId      String
  query       String
  location    String
  radius      String         @default("25")
  concurrency Int            @default(8)
  proxyType   String         @default("residential")
  status      SessionStatus  @default(running)
  totalYield  Int            @default(0)
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  duration    Int?
  errorLog    String?
  config      Json

  user         User           @relation(fields: [userId], references: [id])
  businessLeads BusinessLead[]
  proxySessions ProxySession[]
  exportHistory ExportHistory[]
}

model BusinessLead {
  id            String     @id @default(cuid())
  sessionId     String
  businessName  String
  location      String
  phone         String?
  email         String?
  emailVerified Boolean    @default(false)
  website       String?
  category      String?
  lat           Float?
  lng           Float?
  status        LeadStatus @default(pending)
  createdAt     DateTime   @default(now())

  session        ScrapeSession   @relation(fields: [sessionId], references: [id])
  enrichmentLogs EnrichmentLog[]
}

model EnrichmentLog {
  id           String   @id @default(cuid())
  leadId       String
  source       String
  resultStatus String
  emailFound   Boolean  @default(false)
  apiCostCredits Float?  @default(0)
  enrichedAt   DateTime @default(now())

  lead BusinessLead @relation(fields: [leadId], references: [id])
}

model ProxySession {
  id            String   @id @default(cuid())
  sessionId     String
  proxyIp       String
  provider      String
  successRate   Float?
  requestsMade  Int      @default(0)
  blockedCount  Int      @default(0)
  createdAt     DateTime @default(now())

  session ScrapeSession @relation(fields: [sessionId], references: [id])
}

model ExportHistory {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  format     String
  fileSize   Int?
  downloadedAt DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id])
  session ScrapeSession @relation(fields: [sessionId], references: [id])
}

model UserApiKey {
  id           String   @id @default(cuid())
  userId       String
  provider     String
  encryptedKey String
  keyPrefix    String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model WebhookConfig {
  id         String   @id @default(cuid())
  userId     String   @unique
  webhookUrl String
  secret     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConnectorConfig {
  id          String   @id @default(cuid())
  userId      String
  connectorId String
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, connectorId])
}
