# Database
DATABASE_URL="postgresql://locus:locus_dev@localhost:5433/locus"

# Queue
REDIS_URL="redis://localhost:6379"

# Express Server
SERVER_PORT=4000

# SerpApi (Google Maps search API) — get your key at https://serpapi.com/manage-api-key
SERPAPI_KEY=""

# Enrichment (AI-powered lead enrichment)
# Gemini API key — get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Encryption key for at-rest API key storage — generate with: openssl rand -hex 32
ENRICHMENT_KEY_SECRET=""
# Rate limiting: max enrichments per minute per user
ENRICHMENT_RATE_LIMIT=30
ENRICHMENT_RATE_WINDOW=10

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# Razorpay (Indian market payment gateway)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Frontend (NEXT_PUBLIC_* are exposed to the browser)
NEXT_PUBLIC_WS_URL="ws://localhost:4000/ws"
NEXT_PUBLIC_SERVER_URL="http://localhost:4000"
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
